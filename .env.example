# ====================================================
# SEMICONDUCTOR DASHBOARD - ENVIRONMENT VARIABLES
# ====================================================

# ------- Supabase -------
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------- Finnhub (1차 소스) -------
# https://finnhub.io - Free: 60 req/min
FINNHUB_API_KEY=your-finnhub-api-key

# ------- Alpha Vantage (2차 소스, 일봉 데이터) -------
# https://www.alphavantage.co/support/#api-key - Free: 25 req/day
ALPHA_VANTAGE_API_KEY=your-alphavantage-key

# ------- Cron Secret -------
# openssl rand -base64 32 로 생성
CRON_SECRET=generate-a-random-secret-here

# ------- Optional -------
POLYGON_API_KEY=
